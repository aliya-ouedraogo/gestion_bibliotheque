<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="LibraryMangement" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/LibraryMangement" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-std=c99" />
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/LibraryMangement" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<Unit filename="book.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="book.h">
			<Option target="&lt;{~None~}&gt;" />
		</Unit>
		<Unit filename="borrow.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="borrow.h">
			<Option target="&lt;{~None~}&gt;" />
		</Unit>
		<Unit filename="date_utils.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="date_utils.h">
			<Option target="&lt;{~None~}&gt;" />
		</Unit>
		<Unit filename="file_io.c">
			<Option compilerVar="CC" />
